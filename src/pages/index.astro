---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/style.css';
---

<BaseLayout title="Thomas Schimdst Müller - CV">
  <header class="dash-header">
    <div class="dash-logo" onclick="openNav()">
      <div class="triangle" id="head-triangle"></div>
    </div>
    <nav class="dash-nav">
      <a href="/" class="active">Dashboard</a>
      <a href="#services">Services</a>
      <a href="#skills">Skills</a>
      <a href="#projects">Projects</a>
      <a href="/clock">Clock</a>
    </nav>
    <div class="dash-controls">
      <div class="dash-search">
        <i class="fas fa-search"></i>
      </div>
      <div class="dash-avatar">TM</div>
    </div>
  </header>
  <section class="start">
    <nav id="mySidenav" class="sidenav">
      <a href="javascript:void(0)" class="closebtn" onclick="closeNav()">
        <img src="/media-assets/close.png" alt="close menu" />
      </a>
      <div class="align-row">
        <div class="nav-wrapper">
          <a href="/">Work</a>
          <a href="#">MyCV</a>
          <a href="#">Personal</a>
          <a href="#">About</a>
          <a href="/clock">Time?</a>
        </div>
        <div class="decoration-wrapper">
          <div class="eye"><img src="/media-assets/deco.png" /></div>
        </div>
      </div>
    </nav>

    <div class="main-container">
      <div class="herotxt">
        <div class="slide">
          <h1 class="gradient-text">Thomas Schimdst Müller</h1>
        </div>
        <div class="scroll">
          <h2>
            <span></span> Developer
            <a href="#body">
              <button onclick="playAudio()" type="button">
                <i><iconify-icon icon="bi:heart-fill" width="50" height="50" rotate="45deg"></iconify-icon></i>
              </button>
            </a>
          </h2>
        </div>
      </div>
      <div class="outer-heropic-container">
        <div class="inner-heropic-container">
          <div class="reactor">
            <div class="triangle"></div>
            <div class="circle-1"><span></span><span></span><span></span><span></span></div>
            <div class="circle-2"></div>
            <div class="circle-3"><span></span><span></span><span></span></div>
            <div class="circle-4"><span></span><span></span><span></span></div>
            <div class="circle-5"></div>
            <div class="circle-6"></div>
            <div class="circle-7"><span></span><span></span><span></span></div>
          </div>
        </div>
        <img src="/media-assets/robothand.png" />
      </div>
    </div>
  </section>

  <section class="body" id="body">
    <div class="service" id="services">
      <div class="title">
        <h2 class="gradient-text">Our Services</h2>
      </div>

      <div class="wrapper">
        <div class="box">
          <div class="front-face">
            <div class="icon">
              <i class="fas fa-code"></i>
            </div>
            <span>Web Design</span>
          </div>
          <div class="back-face">
            <span>Web Design</span>
            <p>
              Lorem ipsum dolor sit amet, consectetur adipisicing elit. Rem in deleniti vitae beatae veritatis aliquid porro perspiciatis dolores impedit ad.
            </p>
          </div>
        </div>
        <div class="box">
          <div class="front-face">
            <div class="icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <span>Advertising</span>
          </div>
          <div class="back-face">
            <span>Advertising</span>
            <p>
              Lorem ipsum dolor sit amet, consectetur adipisicing elit. Rem in deleniti vitae beatae veritatis aliquid porro perspiciatis dolores impedit ad.
            </p>
          </div>
        </div>
        <div class="box">
          <div class="front-face">
            <div class="icon">
              <i class="fas fa-rocket"></i>
            </div>
            <span>Game Design</span>
          </div>
          <div class="back-face">
            <span>Game Design</span>
            <p>
              Lorem ipsum dolor sit amet, consectetur adipisicing elit. Rem in deleniti vitae beatae veritatis aliquid porro perspiciatis dolores impedit ad.
            </p>
          </div>
        </div>
      </div>

      <div class="skills" id="skills">
        <div class="title">
          <h2 class="gradient-text">Skills</h2>
        </div>
        <div class="skill-bars">
          <div class="bar">
            <div class="info">
              <span>HTML</span>
            </div>
            <div class="progress-line html">
              <span></span>
            </div>
          </div>
          <div class="bar">
            <div class="info">
              <span>CSS</span>
            </div>
            <div class="progress-line css">
              <span></span>
            </div>
          </div>
          <div class="bar">
            <div class="info">
              <span>jQuery</span>
            </div>
            <div class="progress-line jquery">
              <span></span>
            </div>
          </div>
          <div class="bar">
            <div class="info">
              <span>Python</span>
            </div>
            <div class="progress-line python">
              <span></span>
            </div>
          </div>
          <div class="bar">
            <div class="info">
              <span>MySQL</span>
            </div>
            <div class="progress-line mysql">
              <span></span>
            </div>
          </div>
        </div>
      </div>

      <div class="work-container" id="projects">
        <div class="title">
          <h2 class="gradient-text">Projects</h2>
        </div>
        <div class="work">
          <div class="work-item">
            <div class="work-item-top">
              <i class="fas fa-blog work-icon"></i>
              <span class="work-year">2026</span>
            </div>
            <div class="work-item-content">
              <h3>Blog Post FE</h3>
              <p>Blog frontend built with Astro</p>
              <a href="https://github.com/larvenejafemcoder/BlogPostFE" target="_blank" class="work-link"><i class="fab fa-github"></i> GitHub</a>
            </div>
          </div>
          <div class="work-item">
            <div class="work-item-top">
              <i class="fas fa-code work-icon"></i>
              <span class="work-year">2026</span>
            </div>
            <div class="work-item-content">
              <h3>C Lang Std Libs</h3>
              <p>Custom C standard library implementations</p>
              <a href="https://github.com/larvenejafemcoder/CLang_Stdbased_Libs" target="_blank" class="work-link"><i class="fab fa-github"></i> GitHub</a>
            </div>
          </div>
          <div class="work-item">
            <div class="work-item-top">
              <i class="fas fa-pen work-icon"></i>
              <span class="work-year">2026</span>
            </div>
            <div class="work-item-content">
              <h3>dd Writer Tkinter</h3>
              <p>Disk writer utility (Python + Tkinter)</p>
              <a href="https://github.com/larvenejafemcoder/ddwritertkinter" target="_blank" class="work-link"><i class="fab fa-github"></i> GitHub</a>
            </div>
          </div>
          <div class="work-item">
            <div class="work-item-top">
              <i class="fas fa-cube work-icon"></i>
              <span class="work-year">2026</span>
            </div>
            <div class="work-item-content">
              <h3>Minecraft Beta .NET</h3>
              <p>Minecraft Beta 1.7.3 ported to C#</p>
              <a href="https://github.com/larvenejafemcoder/MinecraftBetaDotnetProj" target="_blank" class="work-link"><i class="fab fa-github"></i> GitHub</a>
            </div>
          </div>
          <div class="work-item">
            <div class="work-item-top">
              <i class="fab fa-linux work-icon"></i>
              <span class="work-year">2026</span>
            </div>
            <div class="work-item-content">
              <h3>Mukus</h3>
              <p>Rufus clone for Linux (Python)</p>
              <a href="https://github.com/larvenejafemcoder/Mukus" target="_blank" class="work-link"><i class="fab fa-github"></i> GitHub</a>
            </div>
          </div>
          <div class="work-item">
            <div class="work-item-top">
              <i class="fas fa-microchip work-icon"></i>
              <span class="work-year">2026</span>
            </div>
            <div class="work-item-content">
              <h3>Reverse Engineering</h3>
              <p>Disassembly &amp; keygen for CrackMe challenges</p>
              <a href="https://github.com/larvenejafemcoder/Reverse_Engineering" target="_blank" class="work-link"><i class="fab fa-github"></i> GitHub</a>
            </div>
          </div>
          <div class="work-item">
            <div class="work-item-top">
              <i class="fab fa-rust work-icon"></i>
              <span class="work-year">2026</span>
            </div>
            <div class="work-item-content">
              <h3>Rust Lang</h3>
              <p>Rust learning repository</p>
              <a href="https://github.com/larvenejafemcoder/Rust-Lang" target="_blank" class="work-link"><i class="fab fa-github"></i> GitHub</a>
            </div>
          </div>
          <div class="work-item">
            <div class="work-item-top">
              <i class="fab fa-java work-icon"></i>
              <span class="work-year">2026</span>
            </div>
            <div class="work-item-content">
              <h3>Sorting Algorithms Java</h3>
              <p>Sorting algorithms in Java</p>
              <a href="https://github.com/larvenejafemcoder/SortingAlgo_Java" target="_blank" class="work-link"><i class="fab fa-github"></i> GitHub</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <h1>Feel free to contact me!</h1>
    <div class="social">
      <div class="social-icon">
        <a href="#"><img src="/media-assets/main/discord.png" /></a>
      </div>
      <div class="social-icon">
        <a href="#"><img src="/media-assets/main/github.png" /></a>
      </div>
      <div class="social-icon">
        <a href="#"><img src="/media-assets/main/linkedin.png" /></a>
      </div>
      <div class="social-icon">
        <a href="#"><img src="/media-assets/main/youtube.png" /></a>
      </div>
      <div class="social-icon">
        <a href="#"><img src="/media-assets/main/facebook.png" /></a>
      </div>
    </div>
    <p>
      @Copyright 2022 by <span class="gradient-text">CyZer0</span>
      <img src="/media-assets/CyZerO.webp" />
    </p>
  </footer>

  <audio id="myAudio">
    <source src="/media-assets/soundtracks/main.mp3" type="audio/mpeg" />
    Your browser does not support the audio element.
  </audio>

  <script src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js" is:inline></script>
  <script src="/myscript.js" is:inline></script>
  <script>
    var x = document.getElementById("myAudio");

    function playAudio() {
      x.play();
    }

    function pauseAudio() {
      x.pause();
    }
  </script>
</BaseLayout>
